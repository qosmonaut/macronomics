# Expo/Metro and React Native do not follow pnpm's default symlinked node_modules
# layout reliably, so we hoist. See ADR-0001 (pitfall #10).
node-linker=hoisted

# Keep the lockfile authoritative and installs reproducible in CI.
prefer-frozen-lockfile=true

# Allow build scripts only for vetted packages (pnpm v10+ blocks by default).
# Add packages here as they are reviewed.
